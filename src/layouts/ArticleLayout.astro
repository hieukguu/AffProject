---
import { getEntry, render, getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorBio from '../components/AuthorBio.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE } from '../lib/site';
import { articleSchema, breadcrumbSchema, faqSchema } from '../lib/schema';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'articles'>;
  path: string;
  sectionLabel: string;
  sectionPath: string;
}

const { entry, path, sectionLabel, sectionPath } = Astro.props;
const data = entry.data;
const { Content } = await render(entry);
const author = await getEntry('authors', data.authorSlug);

const allArticles = await getCollection('articles');
const related = allArticles
  .filter((a) => data.relatedSlugs.includes(a.data.slug) && a.data.slug !== data.slug)
  .slice(0, 3);

const categoryLabel: Record<string, string> = {
  'camping-outdoor': 'Camping & Outdoor Gear',
  'home-essentials': 'Everyday Home Essentials',
  'travel-edc': 'Travel & EDC',
  'fitness-outdoor': 'Fitness & Outdoor Accessories',
};

const crumbs = [
  { name: 'Home', path: '/' },
  { name: sectionLabel, path: sectionPath },
  { name: data.title, path },
];

const schema = [
  articleSchema({
    title: data.title,
    description: data.description,
    slug: data.slug,
    path,
    heroImage: data.heroImage,
    datePublished: data.datePublished,
    dateUpdated: data.dateUpdated,
    author: { name: author!.data.name, slug: author!.data.slug },
  }),
  breadcrumbSchema(crumbs),
];
const faq = faqSchema(data.faq);
if (faq) schema.push(faq);
---

<BaseLayout title={data.title} description={data.description} path={path} image={data.heroImage} type="article" schema={schema}>
  <Breadcrumbs items={crumbs} />

  <article class="mx-auto max-w-4xl px-4 pb-16 pt-6 sm:px-6">
    <header class="mb-6">
      <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-brand-600">
        {categoryLabel[data.category]}
      </p>
      <h1 class="text-3xl font-extrabold leading-tight text-ink-900 sm:text-4xl">{data.title}</h1>
      <p class="mt-3 text-lg text-ink-500">{data.description}</p>
    </header>

    <img
      src={data.heroImage}
      alt={data.heroImageAlt}
      width="1200"
      height="675"
      class="mb-6 aspect-[16/9] w-full rounded-xl object-cover"
    />

    <div class="mb-8">
      <AuthorBio
        authorSlug={data.authorSlug}
        reviewerSlug={data.reviewerSlug}
        datePublished={data.datePublished}
        dateUpdated={data.dateUpdated}
      />
    </div>

    <div class="prose-article">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="mt-12 border-t border-ink-100 pt-8">
        <h2 class="mb-4 text-xl font-bold text-ink-900">Related reading</h2>
        <div class="grid gap-4 sm:grid-cols-3">
          {related.map((r) => {
            const prefix = r.data.tier === 1 ? '' : r.data.tier === 2 ? '/reviews' : '/guides';
            return (
              <ArticleCard
                title={r.data.title}
                description={r.data.description}
                href={`${prefix}/${r.data.slug}`}
                image={r.data.heroImage}
                imageAlt={r.data.heroImageAlt}
                category={categoryLabel[r.data.category]}
                type={r.data.type}
              />
            );
          })}
        </div>
      </section>
    )}

    {SITE.affiliateLinksEnabled && (
      <div class="mt-10 rounded-lg border border-ink-100 bg-ink-50 p-4 text-xs text-ink-500">
        <strong class="text-ink-700">Affiliate disclosure:</strong> {SITE.name} may earn a commission from links on this page.
        Our testing and editorial opinions are never influenced by affiliate partnerships. Learn more in our
        <a href="/affiliate-disclosure" class="text-brand-700 underline">Affiliate Disclosure</a>.
      </div>
    )}
  </article>
</BaseLayout>
