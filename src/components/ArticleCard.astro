---
interface Props {
  title: string;
  description: string;
  href: string;
  image: string;
  imageAlt: string;
  category: string;
  type: string;
  date?: Date;
  size?: 'default' | 'large';
}
const { title, description, href, image, imageAlt, category, type, date, size = 'default' } = Astro.props;

const typeLabel: Record<string, string> = {
  pillar: 'Buying Guide',
  review: 'Review',
  comparison: 'Comparison',
  alternatives: 'Alternatives',
  guide: 'Guide',
};

const label = typeLabel[type] ?? type;

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<a href={href} class="group flex flex-col">
  <div class:list={[
    'relative w-full overflow-hidden rounded-lg bg-ink-100',
    size === 'large' ? 'aspect-[16/9]' : 'aspect-[16/10]',
  ]}>
    <img
      src={image}
      alt={imageAlt}
      loading="lazy"
      width="640"
      height="400"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
    />
  </div>
  <div class="flex flex-1 flex-col pt-3.5">
    <div class="flex items-center gap-1.5">
      <span class="text-[10px] font-black uppercase tracking-[0.12em] text-brand-600">{label}</span>
      <span class="text-ink-300 text-xs">&middot;</span>
      <span class="text-[10px] font-semibold uppercase tracking-wide text-ink-400">{category}</span>
    </div>
    <h3 class:list={[
      'mt-1.5 font-bold leading-snug text-ink-900 transition-colors group-hover:text-brand-700',
      size === 'large' ? 'text-xl sm:text-[22px]' : 'text-[15px]',
    ]}>
      {title}
    </h3>
    {size === 'large' && description && (
      <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-ink-500">{description}</p>
    )}
    {date && (
      <span class="mt-2 text-[11px] font-medium text-ink-400">{formatDate(date)}</span>
    )}
  </div>
</a>
