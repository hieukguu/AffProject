---
interface Crumb {
  name: string;
  path: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mx-auto max-w-4xl px-4 pt-6 text-xs text-ink-500 sm:px-6">
  <ol class="flex flex-wrap items-center gap-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true">/</span>}
        {i === items.length - 1 ? (
          <span class="font-medium text-ink-700" aria-current="page">{item.name}</span>
        ) : (
          <a href={item.path} class="hover:text-brand-700">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
