---
import { getEntry } from 'astro:content';

interface Props {
  authorSlug: string;
  reviewerSlug?: string;
  datePublished: Date;
  dateUpdated: Date;
}

const { authorSlug, reviewerSlug, datePublished, dateUpdated } = Astro.props;
const author = await getEntry('authors', authorSlug);
const reviewer = reviewerSlug ? await getEntry('authors', reviewerSlug) : null;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const updated = dateUpdated.getTime() !== datePublished.getTime();
---

{author && (
  <div class="flex flex-col gap-3 rounded-xl border border-ink-100 bg-ink-50 p-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-3">
      <img src={author.data.avatar} alt={author.data.name} width="44" height="44" class="h-11 w-11 rounded-full bg-ink-200 object-cover" loading="lazy" />
      <div class="text-sm">
        <p class="font-semibold text-ink-900">
          Written by <a href={`/authors/${author.data.slug}`} class="text-brand-700 hover:underline">{author.data.name}</a>
        </p>
        <p class="text-ink-500">{author.data.title}</p>
      </div>
    </div>
    <div class="text-xs text-ink-500 sm:text-right">
      {reviewer && (
        <p>
          Reviewed by <a href={`/authors/${reviewer.data.slug}`} class="text-brand-700 hover:underline">{reviewer.data.name}</a>
        </p>
      )}
      <p>Published {fmt(datePublished)}{updated && <> &middot; Updated {fmt(dateUpdated)}</>}</p>
      <p class="mt-1 inline-flex items-center gap-1 font-medium text-brand-700">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Fact-checked
      </p>
    </div>
  </div>
)}
