---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist or has moved."
  path="/404"
>
  <div class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">404</p>
    <h1 class="mt-3 text-3xl font-extrabold text-ink-900 sm:text-4xl">We couldn't find that page</h1>
    <p class="mt-4 text-ink-500">
      The link might be broken, or the page may have been moved or renamed. Try one of these instead:
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/" class="rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-800">
        Back to homepage
      </a>
      <a href="/reviews" class="rounded-full border border-ink-200 px-6 py-3 text-sm font-semibold text-ink-700 hover:border-brand-300 hover:text-brand-700">
        Browse reviews
      </a>
      <a href="/contact" class="rounded-full border border-ink-200 px-6 py-3 text-sm font-semibold text-ink-700 hover:border-brand-300 hover:text-brand-700">
        Report a broken link
      </a>
    </div>
  </div>
</BaseLayout>
