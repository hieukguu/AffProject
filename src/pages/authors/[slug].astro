---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { authorSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const author = entry.data;

const allArticles = await getCollection('articles');
const byAuthor = allArticles.filter((a) => a.data.authorSlug === author.slug);

const categoryLabel: Record<string, string> = {
  'camping-outdoor': 'Camping & Outdoor Gear',
  'home-essentials': 'Everyday Home Essentials',
  'travel-edc': 'Travel & EDC',
  'fitness-outdoor': 'Fitness & Outdoor Accessories',
};

function hrefFor(a: (typeof allArticles)[number]) {
  if (a.data.tier === 1) return `/${a.data.slug}`;
  if (a.data.tier === 2) return `/reviews/${a.data.slug}`;
  return `/guides/${a.data.slug}`;
}
---

<BaseLayout
  title={`${author.name} — ${author.title}`}
  description={author.bio}
  path={`/authors/${author.slug}`}
  schema={authorSchema(author)}
>
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <div class="flex items-center gap-4">
      <img src={author.avatar} alt={author.name} width="72" height="72" class="h-18 w-18 rounded-full bg-ink-200 object-cover" />
      <div>
        <h1 class="text-2xl font-extrabold text-ink-900">{author.name}</h1>
        <p class="text-brand-700">{author.title}</p>
      </div>
    </div>

    <p class="mt-6 max-w-2xl leading-relaxed text-ink-700">{author.longBio}</p>

    <div class="mt-4 flex flex-wrap gap-2">
      {author.expertise.map((tag: string) => (
        <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">{tag}</span>
      ))}
    </div>

    {byAuthor.length > 0 && (
      <div class="mt-10">
        <h2 class="mb-4 text-xl font-bold text-ink-900">Articles by {author.name}</h2>
        <div class="grid gap-6 sm:grid-cols-2">
          {byAuthor.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={hrefFor(a)}
              image={a.data.heroImage}
              imageAlt={a.data.heroImageAlt}
              category={categoryLabel[a.data.category]}
              type={a.data.type}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
