---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE } from '../lib/site';
import { organizationSchema } from '../lib/schema';

const all = await getCollection('articles');
const pillars = all.filter((a) => a.data.tier === 1);
const latest = all
  .filter((a) => a.data.tier !== 1)
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime())
  .slice(0, 6);

const categoryLabel: Record<string, string> = {
  'camping-outdoor': 'Camping & Outdoor Gear',
  'home-essentials': 'Everyday Home Essentials',
  'travel-edc': 'Travel & EDC',
  'fitness-outdoor': 'Fitness & Outdoor Accessories',
};

function hrefFor(a: (typeof all)[number]) {
  if (a.data.tier === 1) return `/${a.data.slug}`;
  if (a.data.tier === 2) return `/reviews/${a.data.slug}`;
  return `/guides/${a.data.slug}`;
}
---

<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description} path="/" schema={organizationSchema()}>
  <section class="border-b border-ink-100 bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-brand-600">{SITE.niche.primary}</p>
      <h1 class="max-w-2xl text-4xl font-extrabold leading-tight text-ink-900 sm:text-5xl">
        Real gear, tested in real life — not sponsored hype.
      </h1>
      <p class="mt-4 max-w-xl text-lg text-ink-600">
        {SITE.name} reviews camping, outdoor, travel, and everyday home gear so you can buy once and buy right.
        Every recommendation is independently tested or rigorously researched by our editorial team.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/best-camping-gear" class="rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-800">
          Best Camping Gear of {new Date().getFullYear()}
        </a>
        <a href="/reviews" class="rounded-full border border-ink-200 px-6 py-3 text-sm font-semibold text-ink-700 hover:border-brand-300 hover:text-brand-700">
          Browse all reviews
        </a>
      </div>
      <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-xs text-ink-500">
        <span>✓ Independently tested</span>
        <span>✓ Editorially reviewed by 2+ editors</span>
        <span>✓ Affiliate links never influence rankings</span>
        <span>✓ Updated regularly for accuracy</span>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <h2 class="text-2xl font-bold text-ink-900">Shop by category</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {pillars.map((a) => (
        <ArticleCard
          title={a.data.title}
          description={a.data.description}
          href={`/${a.data.slug}`}
          image={a.data.heroImage}
          imageAlt={a.data.heroImageAlt}
          category={categoryLabel[a.data.category]}
          type={a.data.type}
        />
      ))}
    </div>
  </section>

  <section class="bg-ink-50 py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-ink-900">Latest reviews &amp; guides</h2>
        <a href="/reviews" class="text-sm font-semibold text-brand-700 hover:underline">View all &rarr;</a>
      </div>
      <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {latest.map((a) => (
          <ArticleCard
            title={a.data.title}
            description={a.data.description}
            href={hrefFor(a)}
            image={a.data.heroImage}
            imageAlt={a.data.heroImageAlt}
            category={categoryLabel[a.data.category]}
            type={a.data.type}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="rounded-2xl border border-ink-100 bg-white p-8 sm:p-10">
      <h2 class="text-2xl font-bold text-ink-900">How we test &amp; why you can trust us</h2>
      <p class="mt-3 max-w-3xl text-ink-600">
        Every {SITE.name} guide goes through a structured editorial process: a staff writer with category
        expertise drafts the piece from hands-on testing or verified manufacturer data, a senior editor
        fact-checks every claim and spec, and our Editor-in-Chief signs off before publication. We disclose
        affiliate relationships on every page and never accept payment for favorable coverage.
      </p>
      <a href="/editorial-policy" class="mt-4 inline-block text-sm font-semibold text-brand-700 hover:underline">Read our full editorial policy &rarr;</a>
    </div>
  </section>
</BaseLayout>
