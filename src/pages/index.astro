---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE } from '../lib/site';
import { organizationSchema } from '../lib/schema';

const all = await getCollection('articles');
const pillars = all.filter((a) => a.data.tier === 1);
const latest = all
  .filter((a) => a.data.tier !== 1)
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime())
  .slice(0, 6);

const editors = await Promise.all(
  [SITE.editors.editorInChief, SITE.editors.seniorEditor].map((slug) => getEntry('authors', slug)),
);

const categoryLabel: Record<string, string> = {
  'camping-outdoor': 'Camping & Outdoor Gear',
  'home-essentials': 'Everyday Home Essentials',
  'travel-edc': 'Travel & EDC',
  'fitness-outdoor': 'Fitness & Outdoor Accessories',
};

function hrefFor(a: (typeof all)[number]) {
  if (a.data.tier === 1) return `/${a.data.slug}`;
  if (a.data.tier === 2) return `/reviews/${a.data.slug}`;
  return `/guides/${a.data.slug}`;
}
---

<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description} path="/" schema={organizationSchema()}>
  <section class="relative overflow-hidden bg-brand-950">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_15%_20%,theme(colors.brand.800)_0%,transparent_45%),radial-gradient(circle_at_85%_80%,theme(colors.accent.900)_0%,transparent_40%)] opacity-60"></div>

    <div class="relative mx-auto grid max-w-6xl gap-12 px-4 py-16 sm:px-6 sm:py-20 lg:grid-cols-[1.1fr_1fr] lg:items-center lg:py-24">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-brand-200">{SITE.niche.primary}</p>
        <h1 class="max-w-xl text-4xl font-extrabold leading-tight text-white sm:text-5xl">
          Real gear, tested in real life — not sponsored hype.
        </h1>
        <p class="mt-4 max-w-xl text-lg text-brand-50/90">
          {SITE.name} reviews camping, outdoor, travel, and everyday home gear so you can buy once and buy right.
          Every recommendation is independently tested or rigorously researched by our editorial team.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/best-camping-gear" class="rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white hover:bg-accent-600">
            Best Camping Gear of {new Date().getFullYear()}
          </a>
          <a href="/reviews" class="rounded-full border border-white/40 px-6 py-3 text-sm font-semibold text-white hover:border-white hover:bg-white/10">
            Browse all reviews
          </a>
        </div>
        <div class="mt-10 flex flex-wrap gap-2">
          <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-medium text-brand-50 ring-1 ring-white/15">✓ Independently tested</span>
          <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-medium text-brand-50 ring-1 ring-white/15">✓ Reviewed by 2+ editors</span>
          <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-medium text-brand-50 ring-1 ring-white/15">✓ Affiliate links never influence rankings</span>
          <span class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-medium text-brand-50 ring-1 ring-white/15">✓ Updated regularly for accuracy</span>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        <img
          src="/images/hero-camping.jpg"
          alt="Camping & outdoor gear"
          class="aspect-[4/5] w-full translate-y-4 rounded-2xl object-cover shadow-2xl ring-1 ring-white/10"
          loading="eager"
          fetchpriority="high"
        />
        <img
          src="/images/hero-travel.jpg"
          alt="Travel & everyday carry gear"
          class="aspect-[4/5] w-full -translate-y-4 rounded-2xl object-cover shadow-2xl ring-1 ring-white/10"
          loading="eager"
        />
        <img
          src="/images/hero-home.jpg"
          alt="Everyday home essentials"
          class="aspect-[4/5] w-full -translate-y-2 rounded-2xl object-cover shadow-2xl ring-1 ring-white/10"
          loading="lazy"
        />
        <img
          src="/images/hero-outdoor.jpg"
          alt="Outdoor & fitness accessories"
          class="aspect-[4/5] w-full translate-y-2 rounded-2xl object-cover shadow-2xl ring-1 ring-white/10"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <h2 class="text-2xl font-bold text-ink-900">Shop by category</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {pillars.map((a) => (
        <ArticleCard
          title={a.data.title}
          description={a.data.description}
          href={`/${a.data.slug}`}
          image={a.data.heroImage}
          imageAlt={a.data.heroImageAlt}
          category={categoryLabel[a.data.category]}
          type={a.data.type}
        />
      ))}
    </div>
  </section>

  <section class="bg-ink-50 py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-ink-900">Latest reviews &amp; guides</h2>
        <a href="/reviews" class="text-sm font-semibold text-brand-700 hover:underline">View all &rarr;</a>
      </div>
      <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {latest.map((a) => (
          <ArticleCard
            title={a.data.title}
            description={a.data.description}
            href={hrefFor(a)}
            image={a.data.heroImage}
            imageAlt={a.data.heroImageAlt}
            category={categoryLabel[a.data.category]}
            type={a.data.type}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="rounded-2xl border border-ink-100 bg-white p-8 sm:p-10">
      <h2 class="text-2xl font-bold text-ink-900">How we test &amp; why you can trust us</h2>

      <div class="mt-6 grid gap-4 sm:grid-cols-4">
        {[
          { label: 'Draft', detail: 'Staff writer tests hands-on or verifies manufacturer data' },
          { label: 'Fact-check', detail: 'Senior editor verifies every claim and spec' },
          { label: 'Sign-off', detail: 'Editor-in-Chief approves before publishing' },
          { label: 'Disclose', detail: 'Affiliate relationships shown on every page' },
        ].map((step, i) => (
          <div class="relative rounded-xl bg-brand-50 p-4">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-700 text-sm font-bold text-white">{i + 1}</span>
            <p class="mt-3 text-sm font-semibold text-ink-900">{step.label}</p>
            <p class="mt-1 text-xs leading-relaxed text-ink-500">{step.detail}</p>
          </div>
        ))}
      </div>

      <p class="mt-6 max-w-3xl text-ink-600">
        Every {SITE.name} guide goes through a structured editorial process: a staff writer with category
        expertise drafts the piece from hands-on testing or verified manufacturer data, a senior editor
        fact-checks every claim and spec, and our Editor-in-Chief signs off before publication. We disclose
        affiliate relationships on every page and never accept payment for favorable coverage.
      </p>
      <a href="/editorial-policy" class="mt-4 inline-block text-sm font-semibold text-brand-700 hover:underline">Read our full editorial policy &rarr;</a>

      {editors.length > 0 && (
        <div class="mt-8 flex flex-wrap items-center gap-6 border-t border-ink-100 pt-6">
          {editors.map((editor) => editor && (
            <a href={`/authors/${editor.data.slug}`} class="flex items-center gap-3 hover:opacity-80">
              <img src={editor.data.avatar} alt={editor.data.name} width="40" height="40" class="h-10 w-10 rounded-full" />
              <span class="text-sm">
                <span class="block font-semibold text-ink-900">{editor.data.name}</span>
                <span class="text-ink-500">{editor.data.title}</span>
              </span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
