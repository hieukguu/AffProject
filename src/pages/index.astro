---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE } from '../lib/site';
import { organizationSchema } from '../lib/schema';

const all = await getCollection('articles');

const pillars = all
  .filter((a) => a.data.tier === 1)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const reviews = all
  .filter((a) => a.data.tier === 2)
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime());

const guides = all
  .filter((a) => a.data.tier === 3)
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime())
  .slice(0, 4);

const featured = pillars.find((a) => a.data.slug === 'best-camping-gear') ?? pillars[0];
const latestBig = reviews[0];
const latestSmall = reviews.slice(1, 3);

const editors = await Promise.all(
  [SITE.editors.editorInChief, SITE.editors.seniorEditor].map((slug) => getEntry('authors', slug)),
);

const categoryLabel: Record<string, string> = {
  'camping-outdoor': 'Camping & Outdoor',
  'home-essentials': 'Home Essentials',
  'travel-edc': 'Travel & EDC',
  'fitness-outdoor': 'Fitness & Outdoor',
};

function hrefFor(a: (typeof all)[number]) {
  if (a.data.tier === 1) return `/${a.data.slug}`;
  if (a.data.tier === 2) return `/reviews/${a.data.slug}`;
  return `/guides/${a.data.slug}`;
}
---

<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description} path="/" schema={organizationSchema()}>

  <!-- ── HERO FEATURED ── -->
  <section class="relative h-[440px] sm:h-[520px] lg:h-[600px] overflow-hidden">
    <img
      src={featured.data.heroImage}
      alt=""
      width="1400"
      height="600"
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/45 to-transparent" />
    <div class="relative flex h-full flex-col justify-end">
      <div class="mx-auto w-full max-w-6xl px-4 pb-10 sm:px-6 sm:pb-14 lg:pb-16">
        <span class="inline-flex items-center rounded-sm bg-accent-500 px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.15em] text-white">
          Featured Guide
        </span>
        <h1 class="mt-3 max-w-2xl text-3xl font-black leading-tight text-white sm:text-4xl lg:text-[2.75rem]">
          {featured.data.title}
        </h1>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-white/75 sm:text-base">
          {featured.data.description}
        </p>
        <a
          href={hrefFor(featured)}
          class="mt-6 inline-flex items-center gap-2 rounded-full bg-white px-6 py-2.5 text-sm font-bold text-ink-900 transition-colors hover:bg-ink-100"
        >
          Read the full guide <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── LATEST REVIEWS ── -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <div class="mb-7 flex items-center justify-between border-b-2 border-ink-900 pb-3">
      <h2 class="text-xs font-black uppercase tracking-[0.15em] text-ink-900">Latest Reviews</h2>
      <a href="/reviews" class="text-xs font-bold uppercase tracking-wide text-brand-700 hover:underline">View all →</a>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1.7fr_1fr]">
      <!-- Big card -->
      {latestBig && (
        <ArticleCard
          title={latestBig.data.title}
          description={latestBig.data.description}
          href={hrefFor(latestBig)}
          image={latestBig.data.heroImage}
          imageAlt={latestBig.data.heroImageAlt}
          category={categoryLabel[latestBig.data.category] ?? latestBig.data.category}
          type={latestBig.data.type}
          date={latestBig.data.datePublished}
          size="large"
        />
      )}

      <!-- 2 small cards stacked -->
      <div class="flex flex-col divide-y divide-ink-100">
        {latestSmall.map((a) => (
          <div class="py-5 first:pt-0 last:pb-0">
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              href={hrefFor(a)}
              image={a.data.heroImage}
              imageAlt={a.data.heroImageAlt}
              category={categoryLabel[a.data.category] ?? a.data.category}
              type={a.data.type}
              date={a.data.datePublished}
              size="default"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── BUYING GUIDES ── -->
  <section class="border-t border-ink-100 bg-ink-50 py-10 sm:py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mb-7 flex items-center justify-between border-b-2 border-ink-900 pb-3">
        <h2 class="text-xs font-black uppercase tracking-[0.15em] text-ink-900">Buying Guides</h2>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {pillars.map((a) => (
          <ArticleCard
            title={a.data.title}
            description={a.data.description}
            href={hrefFor(a)}
            image={a.data.heroImage}
            imageAlt={a.data.heroImageAlt}
            category={categoryLabel[a.data.category] ?? a.data.category}
            type={a.data.type}
            size="default"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── GEAR GUIDES ── -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <div class="mb-7 flex items-center justify-between border-b-2 border-ink-900 pb-3">
      <h2 class="text-xs font-black uppercase tracking-[0.15em] text-ink-900">Gear Guides</h2>
      <a href="/guides" class="text-xs font-bold uppercase tracking-wide text-brand-700 hover:underline">View all →</a>
    </div>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {guides.map((a) => (
        <ArticleCard
          title={a.data.title}
          description={a.data.description}
          href={hrefFor(a)}
          image={a.data.heroImage}
          imageAlt={a.data.heroImageAlt}
          category={categoryLabel[a.data.category] ?? a.data.category}
          type={a.data.type}
          date={a.data.datePublished}
          size="default"
        />
      ))}
    </div>
  </section>

  <!-- ── EDITORIAL TRUST ── -->
  <section class="border-t border-ink-100 bg-ink-50 py-10 sm:py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-10 lg:grid-cols-[1fr_260px] lg:items-start">
        <div>
          <p class="text-[10px] font-black uppercase tracking-[0.15em] text-brand-600">About {SITE.name}</p>
          <h2 class="mt-2 text-2xl font-black leading-tight text-ink-900 sm:text-3xl">
            Independent reviews.<br />Zero pay-to-play.
          </h2>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ink-600">
            Every guide on {SITE.name} goes through hands-on testing or verified research, fact-checking by a
            senior editor, and sign-off from our Editor-in-Chief before publication. We never accept payment
            for favorable coverage and disclose all affiliate relationships on every page.
          </p>
          <div class="mt-5 flex flex-wrap gap-2">
            {[
              '✓ Independently tested',
              '✓ Reviewed by 2+ editors',
              '✓ Affiliate links never influence rankings',
              '✓ Updated regularly',
            ].map((badge) => (
              <span class="rounded-full border border-ink-200 bg-white px-3 py-1 text-xs font-semibold text-ink-600">
                {badge}
              </span>
            ))}
          </div>
          <a href="/editorial-policy" class="mt-5 inline-block text-sm font-bold text-brand-700 hover:underline">
            Read our editorial policy →
          </a>
        </div>

        {editors.length > 0 && (
          <div class="rounded-xl border border-ink-100 bg-white p-6">
            <p class="mb-4 text-[10px] font-black uppercase tracking-[0.15em] text-ink-400">Our editors</p>
            <div class="flex flex-col gap-5">
              {editors.map((editor) => editor && (
                <a href={`/authors/${editor.data.slug}`} class="flex items-center gap-3 hover:opacity-80 transition-opacity">
                  <img src={editor.data.avatar} alt={editor.data.name} width="48" height="48" class="h-12 w-12 rounded-full ring-2 ring-ink-100" />
                  <span>
                    <span class="block text-sm font-bold text-ink-900">{editor.data.name}</span>
                    <span class="block text-xs text-ink-500 mt-0.5">{editor.data.title}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

</BaseLayout>
